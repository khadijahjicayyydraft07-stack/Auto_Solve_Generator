-- FIX BY GEMINI - NO DOUBLE SOLVE
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local player = Players.LocalPlayer

local cooldownTime = 2 
local lastSolve = 0
local isProcessing = false

local function GetNearestGen()
    local char = player.Character
    if not char then return nil end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end

    local nearest, dist = nil, math.huge
    for _, v in ipairs(workspace:GetDescendants()) do
        if v:IsA("Model") and v.Name:lower():find("gen") then
            local part = v.PrimaryPart or v:FindFirstChildWhichIsA("BasePart")
            if part then
                local d = (hrp.Position - part.Position).Magnitude
                if d < dist then
                    dist = d
                    nearest = v
                end
            end
        end
    end
    return nearest
end

local function Solve()
    local currentTime = tick()
    if isProcessing or (currentTime - lastSolve) < cooldownTime then 
        return 
    end

    local gen = GetNearestGen()
    if not gen then return end

    isProcessing = true
    
    -- JALANKAN SEKALI SAJA (ANTI DOUBLE)
    for _, v in ipairs(gen:GetDescendants()) do
        if v:IsA("RemoteEvent") then
            pcall(function() v:FireServer() end)
        end
    end

    task.wait(0.3)

    local pg = player:FindFirstChild("PlayerGui")
    if pg then
        for _, gui in ipairs(pg:GetDescendants()) do
            if (gui:IsA("TextButton") or gui:IsA("ImageButton")) and gui.Visible then
                pcall(function() gui:Activate() end)
            end
        end
    end

    lastSolve = tick()
    isProcessing = false
    print("✅ Berhasil Solve!")
end

UserInputService.InputBegan:Connect(function(input, gp)
    if not gp and input.KeyCode == Enum.KeyCode.V then
        Solve()
    end
end)

print("Script Ready! Press V")
