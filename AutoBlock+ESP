    BS.isBlocking=true;BS.lastBlock=now;BS.count=BS.count+1
    pcall(function() VIM:SendKeyEvent(true,CFG.BlockKey,false,game) end)
    task.delay(CFG.HoldTime,function()
        pcall(function() VIM:SendKeyEvent(false,CFG.BlockKey,false,game) end)
        BS.isBlocking=false
    end)
    print(string.format("[BLOCK #%d] %s",BS.count,reason))
end

-- ================================================
--  PREDICTION SYSTEM
--  prediction=true      → aktifkan prediksi untuk skill ini
--  predictionLook=true  → cek arah killer menghadap player (prediksi)
--  predictionRange=15   → jarak max prediksi (studs)
--  predictionFuse=true  → harus prediction+predictionLook dua-duanya true
-- ================================================
local PREDICT = {
    PredictTime = 0.15,  -- seberapa jauh ke depan prediksi posisi (detik)
    SpeedMin    = 27,    -- min speed killer buat trigger predict (walk juga masuk)
    CheckRate   = 0.07,  -- polling interval
    Timeout     = 6,     -- max durasi polling
}

-- Prediksi posisi killer setelah PredictTime detik berdasarkan velocity saat ini
local function PredictPos(kHRP)
    local vel = kHRP.AssemblyLinearVelocity
    return kHRP.Position + Vector3.new(vel.X, 0, vel.Z) * PREDICT.PredictTime
end

-- Cek apakah killer (setelah diprediksi) menghadap player
local function DoPredictLook(kHRP, myHRP)
    local predictedPos = PredictPos(kHRP)
    local toPlayer = (myHRP.Position - predictedPos).Unit
    local dot = kHRP.CFrame.LookVector:Dot(toPlayer)
    return dot >= 0.4
end

-- Cek apakah killer akan masuk range block setelah PredictTime
local function DoPredictRange(kHRP, myHRP, range)
    local predictedPos = PredictPos(kHRP)
    return (myHRP.Position - predictedPos).Magnitude <= range
end

-- Fungsi utama: apakah perlu block berdasarkan prediction config di info skill
local function ShouldPredictBlock(kChar, info)
    if not info.prediction then return false end
    local kHRP  = kChar and kChar:FindFirstChild("HumanoidRootPart")
    local myHRP = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not kHRP or not myHRP then return false end

    -- Cek speed killer (walk atau lari)
    local vel = kHRP.AssemblyLinearVelocity
    local spd = Vector3.new(vel.X, 0, vel.Z).Magnitude
    if spd < PREDICT.SpeedMin then return false end

    -- Cek jarak sekarang masih dalam predictionRange
    local dist = (myHRP.Position - kHRP.Position).Magnitude
    local pRange = info.predictionRange or 15
    if dist > pRange then return false end

    local rangeOK = DoPredictRange(kHRP, myHRP, pRange)
    local lookOK  = (not info.predictionLook) or DoPredictLook(kHRP, myHRP)

    if info.predictionFuse then
        return rangeOK and lookOK   -- harus dua-duanya true
    else
        return rangeOK or lookOK    -- salah satu cukup
    end
end

