-- iflook: killer tidak sedang balik belakang penuh ke player
local function KillerFacingOK(kChar)
    local myHRP=player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    local kHRP=kChar and kChar:FindFirstChild("HumanoidRootPart")
    if not myHRP or not kHRP then return true end
    -- dot > -0.5: killer tidak sepenuhnya hadap belakang (boleh block)
    -- dot <= -0.5: killer balik belakang penuh (skip)
    local dot=kHRP.CFrame.LookVector:Dot((myHRP.Position-kHRP.Position).Unit)
    return dot > -0.5
end

-- catch: dodge mundur ke arah belakang character sendiri (bukan ke killer)
local function DodgeBack()
    local char=player.Character;if not char then return end
    local hrp=char:FindFirstChild("HumanoidRootPart");if not hrp then return end
    -- Mundur = negatif LookVector character
    local bv=Instance.new("BodyVelocity")
