    BS.nearDist=bestDist;BS.nearName=best
    if not CFG.BarrierOn or not nearChar then
        local bv=myHRP:FindFirstChild("BarrierBV");if bv then bv:Destroy() end;return
    end
    local kHRP=nearChar:FindFirstChild("HumanoidRootPart");if not kHRP then return end
    local dist=(myHRP.Position-kHRP.Position).Magnitude
    if dist<=CFG.BarrierDanger then
        barrierRotDir=math.random(2)==1 and 1 or -1
        local toK=(kHRP.Position-myHRP.Position).Unit
        local rot=CFrame.fromAxisAngle(Vector3.new(0,1,0),math.rad(90*barrierRotDir))
        local sideDir=(rot*toK).Unit
        local bv=myHRP:FindFirstChild("BarrierBV") or Instance.new("BodyVelocity",myHRP)
        bv.Name="BarrierBV";bv.MaxForce=Vector3.new(1e5,0,1e5);bv.P=1e4;bv.Velocity=sideDir*CFG.BarrierSpeed
    elseif dist<=CFG.BarrierRange then
        local awayDir=(myHRP.Position-kHRP.Position).Unit
        local bv=myHRP:FindFirstChild("BarrierBV") or Instance.new("BodyVelocity",myHRP)
        bv.Name="BarrierBV";bv.MaxForce=Vector3.new(1e5,0,1e5);bv.P=1e4;bv.Velocity=awayDir*CFG.BarrierSpeed
    else
        local bv=myHRP:FindFirstChild("BarrierBV");if bv then bv:Destroy() end
    end
end)

