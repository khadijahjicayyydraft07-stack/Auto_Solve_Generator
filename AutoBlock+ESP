    lbl.TextStrokeTransparency = 0
    lbl.Text = label; lbl.TextSize = 10
    lbl.Font = Enum.Font.GothamBold
    lbl.TextXAlignment = Enum.TextXAlignment.Left

    local track = Instance.new("TextButton", parent)
    track.Size = UDim2.new(0, 46, 0, 24)
    track.Position = UDim2.new(1, -54, 0, yPos + 1)
    track.BorderSizePixel = 0; track.Text = ""
    Instance.new("UICorner", track).CornerRadius = UDim.new(1, 0)

    local ball = Instance.new("Frame", track)
    ball.Size = UDim2.new(0, 18, 0, 18)
    ball.AnchorPoint = Vector2.new(0.5, 0.5)
    ball.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    ball.BorderSizePixel = 0
    Instance.new("UICorner", ball).CornerRadius = UDim.new(1, 0)

    local function Upd(animated)
        local on = getVal()
        local targetBG = on and Color3.fromRGB(60, 210, 90) or Color3.fromRGB(55, 55, 65)
        local targetX  = on and UDim2.new(0, 34, 0.5, 0) or UDim2.new(0, 13, 0.5, 0)
        if animated then
            TweenService:Create(track, TweenInfo.new(0.18, Enum.EasingStyle.Quad), {BackgroundColor3=targetBG}):Play()
            TweenService:Create(ball,  TweenInfo.new(0.18, Enum.EasingStyle.Quad), {Position=targetX}):Play()
        else
            track.BackgroundColor3 = targetBG
            ball.Position = targetX
        end
    end
    Upd(false)
    track.MouseButton1Click:Connect(function() setVal(not getVal()); Upd(true) end)
end

