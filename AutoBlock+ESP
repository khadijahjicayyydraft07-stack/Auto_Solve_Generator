local function SetTrickVelocity(char, active)
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local old = hrp:FindFirstChild("TrickBV")
    if old then old:Destroy() end
    trickBV = nil

    if active then
        local bv = Instance.new("BodyVelocity")
        bv.Name     = "TrickBV"
        bv.MaxForce = Vector3.new(1e4, 0, 1e4)
        bv.P        = 1e3
        bv.Velocity = Vector3.new(0, 0, 0)
        bv.Parent   = hrp
        trickBV  = bv
        trickActive = true
        task.spawn(function()
            while trickActive and hrp and hrp.Parent do
                task.wait()
                if not trickBV or not trickBV.Parent then break end
                local hum = char:FindFirstChildOfClass("Humanoid")
                if hum and hum.MoveDirection.Magnitude > 0 then
                    local dir = hum.MoveDirection
                    trickBV.Velocity = Vector3.new(
                        dir.X * TRICK.SlowVelocity,
                        0,
                        dir.Z * TRICK.SlowVelocity
                    )
                else
                    trickBV.Velocity = Vector3.new(0, 0, 0)
                end
            end
        end)
    else
        trickActive = false
    end
end

local function PlayTrick()
    local char = player.Character; if not char then return end
    local hum  = char:FindFirstChildOfClass("Humanoid"); if not hum then return end
    local anim = Instance.new("Animation"); anim.AnimationId = TRICK.AnimId
    local track = hum:LoadAnimation(anim)

    if TRICK.IfAnimLoop then
        if trickLooping then
            trickLooping = false
            if trickTrack then trickTrack:Stop() end
            SetTrickVelocity(char, false)
        else
            trickLooping = true; trickTrack = track
            track.Looped = true; track:Play()
            SetTrickVelocity(char, true)
        end
    else
        track.Looped = false; track:Play()
        SetTrickVelocity(char, true)
        track.Stopped:Connect(function()
            SetTrickVelocity(char, false)
            trickLooping = false
        end)
    end
end

