--  HOOK KILLER
-- ================================================
local hooked={};local prevAbils={}
local function HookKillerChar(char,pName)
    if not char or hooked[char] or char==player.Character then return end
    if not IsKillerChar(char) then return end
    hooked[char]=true;prevAbils[char]=char:GetAttribute("AbilitiesUsed") or 0
    local kn=GetKillerName(char);local kCFG=KILLER_CONFIG[kn]
    print(string.format("[HOOK] %s (%s) %s",kn,pName,kCFG and "✓config" or "no config"))
    local hum=char:FindFirstChildOfClass("Humanoid")
    if hum then
        local animator=hum:FindFirstChildOfClass("Animator")
        if animator then
            animator.AnimationPlayed:Connect(function(animTrack)
                if not CFG.AutoBlock then return end
                local id=getAnimId(animTrack.Animation and animTrack.Animation.AnimationId or "")
                if id=="" then return end
                if kCFG then
                    local info=kCFG[id]
                    if not info then print(string.format("[SKIP-UNK] %s id=%s",kn,id));return end
                    if not info.block then BS.lastSkip=info.name;print(string.format("[SKIP] %s %s",kn,info.name));return end

                    -- block=true
                    if info.block==true then
                        local dist=GetDist(char)
                        local rangeOK=FAR_BLOCK_ANIMS[id] and dist<=30 or dist<=CFG.BlockRange
                        if rangeOK then BS.lastSkill=info.name;Block(string.format("%s %s",kn,info.name),false) end
                        return
                    end

                    -- block="speed"
                    if info.block=="speed" then
                        local sMin=info.speedMin or 30;local sRange=info.range or 30
                        local kHRP=char:FindFirstChild("HumanoidRootPart")
                        local myHRP=player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                        if not kHRP or not myHRP then return end
                        task.spawn(function()
                            local prev=kHRP.Position;local t0=tick();local done=false
                            while char and char.Parent and animTrack.IsPlaying do
                                task.wait(0.1);if done then break end
                                local curr=kHRP.Position
                                local spd=(curr-prev).Magnitude/0.1;prev=curr
                                local dist=(myHRP.Position-curr).Magnitude
                                local facing=kHRP.CFrame.LookVector:Dot((myHRP.Position-curr).Unit)>0.4
                                if spd>=sMin and facing and dist<=sRange then
                                    BS.lastSkill=string.format("%s spd=%.1f",info.name,spd)
                                    Block(string.format("%s %s [spd=%.1f]",kn,info.name,spd),false)
                                    done=true
                                end
                                if tick()-t0>6 then break end
                            end
                        end)
                        return
                    end

                    -- block="owner"
                    if info.block=="owner" then
                        local kHRP=char:FindFirstChild("HumanoidRootPart")
                        local myHRP=player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                        if not kHRP or not myHRP then return end
                        task.spawn(function()
                            local prev=kHRP.Position;local t0=tick();local done=false
                            while char and char.Parent and animTrack.IsPlaying do
                                task.wait(0.1);if done then break end
                                local curr=kHRP.Position
                                local dist=(myHRP.Position-curr).Magnitude
                                local facing=kHRP.CFrame.LookVector:Dot((myHRP.Position-curr).Unit)>0.4

                                -- iflook check
                                if info.iflook and not KillerFacingOK(char) then
                                    prev=curr
                                    if tick()-t0>6 then break end
                                    continue
                                end

                                local shouldBlock=false
                                if info.speed then
                                    local spd=(curr-prev).Magnitude/0.1
                                    if spd>=(info.speedMin or 30) and facing and dist<=(info.range or 30) then
                                        shouldBlock=true;BS.lastSkill=string.format("%s spd=%.1f",info.name,spd)
                                    end
                                else
                                    if dist<=(info.range or CFG.BlockRange) and facing then
                                        shouldBlock=true;BS.lastSkill=info.name
                                    end
                                end
                                prev=curr
                                if shouldBlock then
                                    done=true
                                    if info.hold and info.hold>0 then task.wait(info.hold) end
                                    Block(string.format("%s %s [owner]",kn,info.name),info.catch or false)
                                end
                                if tick()-t0>6 then break end
                            end
                        end)
                        return
                    end
                else
                    local dist=GetDist(char)
                    if dist<=CFG.BlockRange then BS.lastSkill="unk:"..id;Block(string.format("%s unk:%s",kn,id),false) end
                end
            end)
        end
    end
    char.AncestryChanged:Connect(function() if not char.Parent then hooked[char]=nil;prevAbils[char]=nil end end)
end

