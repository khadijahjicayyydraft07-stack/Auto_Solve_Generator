local function Block(reason,doCatch)
    if not CFG.AutoBlock then return end
    local now=tick()
    if now-BS.lastBlock<CFG.Cooldown or BS.isBlocking then return end
    BS.isBlocking=true;BS.lastBlock=now;BS.count=BS.count+1
    if doCatch then DodgeBack() end
    pcall(function() VIM:SendKeyEvent(true,CFG.BlockKey,false,game) end)
    task.delay(CFG.HoldTime,function()
        pcall(function() VIM:SendKeyEvent(false,CFG.BlockKey,false,game) end)
        BS.isBlocking=false
    end)
    print(string.format("[BLOCK #%d] %s",BS.count,reason))
end

